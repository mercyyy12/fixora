{"ast":null,"code":"import{createContext,useContext,useState,useCallback}from'react';import{jsx as _jsx}from\"react/jsx-runtime\";const ToastContext=/*#__PURE__*/createContext(null);export function ToastProvider(_ref){let{children}=_ref;const[toasts,setToasts]=useState([]);const showToast=useCallback(msg=>{const id=Date.now();setToasts(prev=>[...prev,{id,msg}]);setTimeout(()=>setToasts(prev=>prev.filter(t=>t.id!==id)),3400);},[]);return/*#__PURE__*/_jsx(ToastContext.Provider,{value:{toasts,showToast},children:children});}export const useToast=()=>useContext(ToastContext);","map":{"version":3,"names":["createContext","useContext","useState","useCallback","jsx","_jsx","ToastContext","ToastProvider","_ref","children","toasts","setToasts","showToast","msg","id","Date","now","prev","setTimeout","filter","t","Provider","value","useToast"],"sources":["/home/init0/Documents/fixora_final/fixora/client/src/context/landing/ToastContext.jsx"],"sourcesContent":["import { createContext, useContext, useState, useCallback } from 'react'\n\nconst ToastContext = createContext(null)\n\nexport function ToastProvider({ children }) {\n  const [toasts, setToasts] = useState([])\n\n  const showToast = useCallback((msg) => {\n    const id = Date.now()\n    setToasts(prev => [...prev, { id, msg }])\n    setTimeout(() => setToasts(prev => prev.filter(t => t.id !== id)), 3400)\n  }, [])\n\n  return (\n    <ToastContext.Provider value={{ toasts, showToast }}>\n      {children}\n    </ToastContext.Provider>\n  )\n}\n\nexport const useToast = () => useContext(ToastContext)\n"],"mappings":"AAAA,OAASA,aAAa,CAAEC,UAAU,CAAEC,QAAQ,CAAEC,WAAW,KAAQ,OAAO,QAAAC,GAAA,IAAAC,IAAA,yBAExE,KAAM,CAAAC,YAAY,cAAGN,aAAa,CAAC,IAAI,CAAC,CAExC,MAAO,SAAS,CAAAO,aAAaA,CAAAC,IAAA,CAAe,IAAd,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACxC,KAAM,CAACE,MAAM,CAAEC,SAAS,CAAC,CAAGT,QAAQ,CAAC,EAAE,CAAC,CAExC,KAAM,CAAAU,SAAS,CAAGT,WAAW,CAAEU,GAAG,EAAK,CACrC,KAAM,CAAAC,EAAE,CAAGC,IAAI,CAACC,GAAG,CAAC,CAAC,CACrBL,SAAS,CAACM,IAAI,EAAI,CAAC,GAAGA,IAA